---
import Container from "./Container.astro"
---

<div class="relative" id="home">
    <div aria-hidden="true" class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-40 dark:opacity-20">
        <div class="blur-[106px] h-56 bg-gradient-to-br from-primary to-purple-400 dark:from-blue-700"></div>
        <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-400 to-sky-300 dark:to-indigo-600"></div>
    </div>
    <Container>
        <div class="relative pt-36 ml-auto">
            <div class="lg:w-2/3 text-center mx-auto">
                <h1 class="text-gray-900 text-balance dark:text-white font-bold text-5xl md:text-6xl xl:text-7xl">Take <span class="text-primary dark:text-white">control</span> of your nutrition. </h1>
                <p class="mt-8 text-gray-700 dark:text-gray-300">The first at-home testing kit to provide a complete nutrition analysis
                  </p>
                <p class=" text-gray-700 dark:text-gray-300">   <b> at the click of a button. </b></p>
                <div class="mt-16 flex flex-col items-center gap-4">

                  <!-- Email signup -->
                  <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 w-full max-w-md">
                    <input
                      id="waitlist-email"
                      type="email"
                      placeholder="Enter your email"
                       required
                      class="flex-1 px-5 py-3 rounded-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary text-sm"
                    />
                    <button
                      type="submit"
                      class="relative flex h-11 items-center justify-center px-6 before:absolute before:inset-0 before:rounded-full before:bg-primary before:transition before:duration-300 hover:before:scale-105 active:duration-75 active:before:scale-95 sm:w-max"
                    >
                      <span class="relative text-base font-semibold text-white">Join waitlist</span>
                    </button>
                  </form>

                  <!-- Success message (hidden by default) -->
                  <p id="waitlist-success" class="hidden text-sm text-green-500 font-medium">
                    You're on the list! We'll be in touch.
                  </p>

                  <!-- Counter -->
                  <p class="text-sm text-gray-500 dark:text-gray-400">
                    <span id="waitlist-count" class="font-semibold text-gray-900 dark:text-white">—</span>
                    people already on the waitlist
                  </p>
                </div>

                <script>
                  const form = document.getElementById("waitlist-form") as HTMLFormElement
                  const input = document.getElementById("waitlist-email") as HTMLInputElement
                  const success = document.getElementById("waitlist-success")!
                  const counter = document.getElementById("waitlist-count")!

                  // Load the real count on page load
                  async function updateCounter() {
                    try {
                      const res = await fetch("/api/waitlist/count")
                      const data = await res.json()
                      counter.textContent = String(data.count ?? 0)
                    } catch {
                      counter.textContent = "0"
                    }
                  }

                  // Handle form submission
                  form.addEventListener("submit", async (e) => {
                    e.preventDefault()
                    const email = input.value.trim().toLowerCase()

                    const res = await fetch("/api/waitlist", {
                      method: "POST",
                      headers: { "Content-Type": "application/json" },
                      body: JSON.stringify({ email })
                    })

                    const data = await res.json()

                    if (res.status === 409) {
                      success.textContent = "You're already on the list!"
                      success.classList.remove("hidden")
                      return
                    }

                    if (!res.ok) {
                      success.textContent = "Something went wrong. Please try again."
                      success.classList.remove("hidden")
                      success.classList.add("text-red-500")
                      return
                    }

                    input.value = ""
                    success.textContent = "You're on the list! We'll be in touch."
                    success.classList.remove("hidden")
                    updateCounter()
                  })

                  updateCounter()
                </script>
                
                <div class="hidden py-8 mt-16 border-y border-gray-100 dark:border-gray-800 sm:flex justify-between">
                    <div class="text-left">
                        <h6 class="text-lg font-semibold text-gray-700 dark:text-white">A new way to test</h6>
                        <p class="mt-2 text-gray-500">No labs, no doctors,</p>
                        <p class="text-gray-500">no hassle.</p>
                    </div>
                    <div class="text-left">
                        <h6 class="text-lg font-semibold text-gray-700 dark:text-white">The fastest on the market</h6>
                        <p class="mt-2 text-gray-500">Results in under 15 minutes.</p>
                    </div>
                    <div class="text-left">
                        <h6 class="text-lg font-semibold text-gray-700 dark:text-white">No peripherals needed</h6>
                        <p class="mt-2 text-gray-500"> Test anywhere, any time.</p>
                    </div>
                </div>
            </div>
            <div class="mt-12 grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6">
                <div class="p-4 grayscale transition duration-200 hover:grayscale-0">
                    <img src="./images/clients/WUR.jpg" class="h-14 w-auto mx-auto" loading="lazy" alt="client logo" width="" height="" />
                  </div>
                <div class="p-4 grayscale transition duration-200 hover:grayscale-0">
                  <img src="./images/clients/SSDx.jpg" class="h-14 w-auto mx-auto" loading="lazy" alt="client logo" width="" height="" />
                </div>
                <div class="p-4 flex grayscale transition duration-200 hover:grayscale-0">
                  <img src="./images/clients/google.svg" class="h-9 w-auto m-auto" loading="lazy" alt="client logo" width="" height="" />
                </div>
                <div class="p-4 grayscale transition duration-200 hover:grayscale-0">
                    <img src="./images/clients/ge.svg" class="h-12 w-auto mx-auto" loading="lazy" alt="client logo" width="" height="" />
                  </div>
                  <div class="p-4 flex grayscale transition duration-200 hover:grayscale-0">
                    <img src="./images/clients/netflix.svg" class="h-8 w-auto m-auto" loading="lazy" alt="client logo" width="" height="" />
                  </div>
                <div class="p-4 grayscale transition duration-200 hover:grayscale-0">
                    <img src="./images/clients/google-cloud.svg" class="h-12 w-auto mx-auto" loading="lazy" alt="client logo" width="" height="" />
                </div>
              </div>
        </div>
    </Container>
</div>